{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Profile",
  "description": "Schema for Nexus OS Environment Manifest. Per the Protocol: no 'run:' commands are ever allowed.",
  "type": "object",
  "required": ["name", "version"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Profile identifier, lowercase alphanumeric with hyphens"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "maxLength": 256
    },
    "author": {
      "type": "string",
      "maxLength": 128
    },
    "extends": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Profile to inherit from — packages are additive, env vars are overridden by child"
    },
    "targets": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["family", "packages"],
        "additionalProperties": false,
        "properties": {
          "family": {
            "type": "string",
            "enum": ["debian", "ubuntu", "arch", "fedora", "alpine", "linux"]
          },
          "packages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._+-]*$",
              "description": "Package name — must be a valid package identifier, no shell metacharacters"
            }
          }
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Environment variables to set"
    }
  }
}
