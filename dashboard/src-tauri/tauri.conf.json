{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus Dashboard",
  "version": "0.10.0",
  "identifier": "local.nexus.dashboard",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Nexus Dashboard",
        "width": 960,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/nexus"],
    "resources": []
  }
}
